    document.getElementById('helpHome').style.display='none';
    document.getElementById('helpArticle').style.display='block';

    document.getElementById('articleContent').innerHTML=` <div style="margin-bottom:14px;font-size:12px;color:var(--gris-texto);display:flex;align-items:center;gap:6px;cursor:pointer;" onclick="showHelpHome()"><i class="bi bi-arrow-left"></i>Volver a ayuda </div><div style="background:white;border:1px solid var(--gris-borde);border-radius:var(--r-lg);padding:32px;max-width:700px;"><div style="font-size:11px;font-weight:700;background:var(--azul-light);color:var(--azul);padding:3px 10px;border-radius:12px;display:inline-block;margin-bottom:14px;">$ {
