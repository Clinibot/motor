# ─────────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────────

# URL del proyecto Supabase (pública)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clave anónima de Supabase (pública, segura para el cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Clave de service role (PRIVADA — solo server-side, nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─────────────────────────────────────────────
# OPENAI
# ─────────────────────────────────────────────

# Necesaria para el webhook inbound: formatea la disponibilidad en lenguaje natural
# Sin esta variable, el webhook devuelve _debug: missing_openai_key y no inyecta variables
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────
# EMAIL (Resend)
# ─────────────────────────────────────────────

# Para envío de alertas y notificaciones por email
RESEND_API_KEY=re_...

# ─────────────────────────────────────────────
# SITE URL
# ─────────────────────────────────────────────

# URL pública del deploy (usada para construir webhook URLs)
# En Vercel se rellena automáticamente con VERCEL_URL, pero mejor definirla explícitamente
NEXT_PUBLIC_SITE_URL=https://lafabrica.netelip.com

# ─────────────────────────────────────────────
# CRON
# ─────────────────────────────────────────────

# Secret para proteger los endpoints de cron (alertas diarias, etc.)
# Debe coincidir con el header Authorization que envía Vercel Cron
CRON_SECRET=un-secreto-seguro-aqui

# ─────────────────────────────────────────────
# CAL.COM (guard de seguridad)
# ─────────────────────────────────────────────

# Secret opcional que protege los endpoints Cal.com de la fábrica.
# Si está configurado, los endpoints verifican que el header x-factory-secret coincida.
# Genera una cadena aleatoria, ej: openssl rand -base64 32
FACTORY_CALCOM_SECRET=

# ─────────────────────────────────────────────
# NOTAS
# ─────────────────────────────────────────────
# Las Retell API Keys NO están aquí — cada workspace tiene la suya propia
# y se almacenan en la tabla `workspaces` de Supabase.
#
# Las Cal.com API Keys tampoco están aquí — se configuran por agente
# en el wizard (Paso 5 → Herramientas → Agenda) y se guardan en
# la tabla `agents.configuration` de Supabase.
#
# No existe RETELL_WEBHOOK_SECRET — Retell no tiene un secret de webhook
# separado. La firma x-retell-signature se verifica con la API key del
# workspace almacenada en Supabase. Ver CLAUDE.md para más contexto.
